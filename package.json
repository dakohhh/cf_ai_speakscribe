{
  "name": "speakscribe",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "migrations": "drizzle-kit generate",
    "migrate:dev": "wrangler d1 migrations apply speakscribe --local",
    "migrate": "wrangler d1 migrations apply speakscribe --remote",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@libsql/client": "^0.17.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.3",
    "http-status-codes": "^2.3.0",
    "oslo": "^1.2.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260301.1",
    "@typescript-eslint/eslint-plugin": "6.0.0",
    "@typescript-eslint/parser": "6.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "8.42.0",
    "eslint-config-prettier": "9.0.0",
    "eslint-plugin-prettier": "5.0.0",
    "prettier": "3.0.0",
    "wrangler": "^4.4.0"
  }
}